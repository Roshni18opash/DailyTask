<!DOCTYPE html>
<html>
<head>
  <title>Add Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav class="navbar">
  <div class="nav-left">
    <h2>Add New Blog</h2>
  </div>

  <div class="nav-right">
    <a href="/" class="nav-btn">Blogs</a>
    <a href="/logout" class="logout-btn">Logout</a>
  </div>
</nav>

<div class="container">

  <div class="blog-card" style="max-width:600px; margin:auto;">
    <h3>Add Blog</h3>

    <form action="/submit" method="post">

      <div style="margin-bottom:15px;">
        <label>Title</label>
        <input type="text" name="title" required style="width:100%; padding:8px;">
      </div>

      <div style="margin-bottom:15px;">
        <label>Image URL</label>
        <input type="url" name="image" required style="width:100%; padding:8px;">
      </div>

      <div style="margin-bottom:15px;">
        <label>Blogger Name</label>
        <input type="text" name="bname" required style="width:100%; padding:8px;">
      </div>

      <div style="margin-bottom:15px;">
        <label>Category</label>
        <input type="text" name="type" required style="width:100%; padding:8px;">
      </div>

      <div style="margin-bottom:15px;">
        <label>Date</label>
        <input type="date" name="date" required style="width:100%; padding:8px;">
      </div>

      <div style="margin-bottom:15px;">
        <label>Description</label>
        <textarea name="dsc" rows="4" required style="width:100%; padding:8px;"></textarea>
      </div>

      <button type="submit" class="nav-btn add-btn">Submit</button>

    </form>

  </div>

</div>

</body>
</html>
