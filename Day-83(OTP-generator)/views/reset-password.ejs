<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Set New Password - Matrix Next</title>
  <link rel="stylesheet" href="/css/modern.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body>
  <div class="auth-container">
    <div class="auth-card">
      <div class="text-center mb-4">
        <div class="stat-icon purple" style="width: 70px; height: 70px; margin: 0 auto 1.5rem; font-size: 2rem;">
            <i class="fas fa-shield-alt"></i>
        </div>
        <h1>New Password</h1>
        <p class="subtitle">Set a secure password for your account.</p>
      </div>

      <form action="/reset-password" method="POST">
        <div class="form-group">
          <label>New Password</label>
          <div class="input-wrapper">
            <input type="password" name="password" placeholder="Create new password" required>
          </div>
        </div>

        <div class="form-group">
          <label>Confirm Password</label>
          <div class="input-wrapper">
            <input type="password" placeholder="Repeat new password" required>
          </div>
        </div>

        <button type="submit" class="btn btn-primary">
            Reset Password
        </button>

        <div class="footer-links">
          <a href="/login" class="link">Back to Sign In</a>
        </div>
      </form>
    </div>
  </div>
</body>

</html>
