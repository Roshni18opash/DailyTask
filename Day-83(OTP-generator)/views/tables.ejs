<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Members - Matrix Next</title>
  <link rel="stylesheet" href="/css/modern.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body style="display: block; background: #0b0f1a; min-height: 100vh;">
  
  <%- include("./partials/header.ejs") %>
  
  <%- include("./partials/aside.ejs") %>

  <main class="dashboard-content" style="margin-left: 260px; margin-top: 70px; padding: 3rem;">
    <div class="content-header">
      <div class="welcome-section">
        <h1>Members List</h1>
        <p class="subtitle text-start" style="text-align: left;">Manage all registered users in the system.</p>
      </div>
    </div>

    <div class="modern-table-container">
      <div class="section-title">
        <h2>Registered Users</h2>
        <div class="date-display"><%= data.length %> Total Members</div>
      </div>
      
      <table>
        <thead>
          <tr>
            <th><i class="fas fa-user"></i> Username</th>
            <th><i class="fas fa-envelope"></i> Email Address</th>
            <th><i class="fas fa-key"></i> Password (Raw)</th>
            <th style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% data.map((val)=>{ let {username, email, password} = val; %>
          <tr>
            <td>
              <div style="display: flex; align-items: center; gap: 0.8rem;">
                <div class="avatar" style="width: 32px; height: 32px; font-size: 0.8rem;"><%= username.charAt(0).toUpperCase() %></div>
                <strong><%= username %></strong>
              </div>
            </td>
            <td><%= email %></td>
            <td><code style="background: rgba(255,255,255,0.05); padding: 0.2rem 0.5rem; border-radius: 4px;"><%= password %></code></td>
            <td style="text-align: right;">
              <button class="action-btn" style="background: rgba(99, 102, 241, 0.1); color: #6366f1; border: none; display: inline-flex; margin-right: 0.5rem;"><i class="fas fa-edit"></i></button>
              <button class="action-btn delete-btn" style="display: inline-flex;"><i class="fas fa-trash"></i></button>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </main>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script>
    $(".preloader").fadeOut();
  </script>
</body>

</html>