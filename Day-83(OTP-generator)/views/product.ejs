<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Catalog - Matrix Next</title>
    <link rel="stylesheet" href="/css/modern.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body style="display: block; background: #0b0f1a; min-height: 100vh;">

    <%- include("./partials/header.ejs") %>

    <%- include("./partials/aside.ejs") %>

    <main class="dashboard-content" style="margin-left: 260px; margin-top: 70px; padding: 3rem;">
        <div class="content-header" style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem;">
            <div class="welcome-section">
                <h1>Product Inventory</h1>
                <p class="subtitle text-start" style="text-align: left; margin-bottom: 0;">High-quality overview of your current stock.</p>
            </div>
            <a href="/form-basic" class="btn btn-primary" style="width: auto; padding: 0.8rem 2rem; background: linear-gradient(135deg, #a855f7, #6366f1); border-radius: 12px; font-weight: 700; transform: none; box-shadow: 0 10px 20px -5px rgba(168, 85, 247, 0.4);">
                <i class="fas fa-plus"></i> Add New Product
            </a>
        </div>

        <div class="product-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2.5rem;">
            <% data.forEach((item, index) => { 
                const gradients = [
                    'linear-gradient(135deg, #6366f1, #a855f7)',
                    'linear-gradient(135deg, #10b981, #3b82f6)',
                    'linear-gradient(135deg, #f59e0b, #ec4899)',
                    'linear-gradient(135deg, #ef4444, #f59e0b)'
                ];
                const grad = gradients[index % gradients.length];
            %>
            <div class="product-card" style="position: relative; border-radius: 24px; background: rgba(30, 41, 59, 0.4); border: 1px solid rgba(255, 255, 255, 0.05); overflow: hidden; transition: all 0.4s ease;">
                <!-- Decorative accent -->
                <div style="height: 6px; background: <%= grad %>; width: 100%;"></div>
                
                <div class="product-image" style="height: 240px; position: relative; overflow: hidden;">
                    <img src="<%= item.image %>" alt="<%= item.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);">
                    <div style="position: absolute; top: 1rem; right: 1rem; background: <%= grad %>; color: white; padding: 0.4rem 0.9rem; border-radius: 10px; font-weight: 800; font-size: 0.85rem; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.5);">
                        <i class="fas fa-star"></i> <%= item.rate %>
                    </div>
                </div>

                <div style="padding: 1.8rem;">
                    <h3 style="color: white; font-size: 1.25rem; font-weight: 700; margin-bottom: 0.8rem; letter-spacing: -0.02em;"><%= item.title %></h3>
                    <p style="color: #94a3b8; font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem;"><%= item.dsc %></p>
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.08);">
                        <div>
                            <span style="font-size: 0.75rem; color: #64748b; font-weight: 700; text-transform: uppercase; display: block; margin-bottom: 2px;">Market Value</span>
                            <span style="font-size: 1.5rem; font-weight: 900; color: white; letter-spacing: -0.03em;">$<%= (item.rate * 19.99).toFixed(2) %></span>
                        </div>
                        <div style="display: flex; gap: 0.8rem;">
                            <a href="/product/delete/<%= item.id %>" class="action-btn" style="width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.1); transition: all 0.3s ease;">
                                <i class="fas fa-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </main>

    <style>
        .product-card:hover { transform: translateY(-12px); border-color: rgba(255,255,255,0.15); box-shadow: 0 30px 60px -12px rgba(0,0,0,0.6); }
        .product-card:hover img { transform: scale(1.15); }
        .action-btn:hover { background: #ef4444 !important; color: white !important; transform: scale(1.1); box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4); }
    </style>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(".preloader").fadeOut();
    </script>
</body>

</html>