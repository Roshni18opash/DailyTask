<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile - Matrix Next</title>
  <link rel="stylesheet" href="/css/modern.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body style="display: block; background: #0b0f1a; min-height: 100vh;">
  
  <%- include("./partials/header.ejs") %>
  
  <%- include("./partials/aside.ejs") %>

  <main class="dashboard-content" style="margin-left: 260px; margin-top: 70px; padding: 3rem;">
    <div class="content-header">
      <div class="welcome-section">
        <h1>My Profile</h1>
      </div>
    </div>

    <div class="auth-card" style="width: 100%; max-width: 500px; margin: 0 auto; background: rgba(30, 41, 59, 0.5);">
      <div class="text-center mb-4">
        <div class="avatar" style="width: 80px; height: 80px; font-size: 2.5rem; margin: 0 auto 1.5rem;">
          <%= user.username.charAt(0).toUpperCase() %>
        </div>
      </div>

      <div class="form-group">
        <label>Username</label>
        <div class="input-wrapper">
          <input type="text" value="<%= user.username %>" disabled>
        </div>
      </div>

      <div class="form-group">
        <label>Email Address</label>
        <div class="input-wrapper">
          <input type="email" value="<%= user.email %>" disabled>
        </div>
      </div>

      <div class="form-group">
        <label>Contact Number</label>
        <div class="input-wrapper">
          <input type="tel" value="<%= user.phone %>" disabled>
        </div>
      </div>

      <div class="divider">Account Actions</div>

      <div class="action-buttons">
        <a href="/changepassword" class="btn btn-secondary"><i class="fas fa-lock"></i> Change Password</a>
        <a href="/logout" class="btn btn-secondary" style="border-color: var(--error); color: var(--error);"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
  </main>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script>
    $(".preloader").fadeOut();
  </script>
</body>

</html>