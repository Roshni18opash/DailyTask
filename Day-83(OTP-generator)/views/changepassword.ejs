<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password - Matrix Next</title>
    <link rel="stylesheet" href="/css/modern.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body style="display: block; background: #0b0f1a; min-height: 100vh;">

    <%- include("./partials/header.ejs") %>

    <%- include("./partials/aside.ejs") %>

    <main class="dashboard-content" style="margin-left: 260px; margin-top: 70px; padding: 3rem;">
        <div class="content-header">
            <div class="welcome-section">
                <h1>Security Settings</h1>
                <p class="subtitle text-start" style="text-align: left;">Update your password regularly to keep your account secure.</p>
            </div>
        </div>

        <div class="auth-card" style="width: 100%; max-width: 500px; margin: 0 auto; background: rgba(30, 41, 59, 0.5);">
            <div class="text-center mb-4">
                <div class="stat-icon purple" style="width: 70px; height: 70px; margin: 0 auto 1.5rem; font-size: 2rem;">
                    <i class="fas fa-key"></i>
                </div>
                <h2>Change Password</h2>
            </div>

            <form action="/changepassword" method="POST">
                <div class="form-group">
                    <label>Old Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="oldpassword" placeholder="Enter current password" required>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 2rem;">
                    <label>New Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="newpassword" placeholder="Enter new password" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Confirm New Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="confirmpassword" placeholder="Repeat new password" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="margin-top: 2rem;">
                    <i class="fas fa-shield-alt"></i> Update Password
                </button>

                <div class="footer-links" style="margin-top: 1.5rem;">
                    <a href="/profile" class="link">Back to Profile</a>
                </div>
            </form>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(".preloader").fadeOut();
    </script>
</body>

</html>