<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Image</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <h1>Edit Image</h1>
<form action="/image/<%= image._id %>?_method=PUT" method="POST">
    <input type="text" name="title" value="<%= image.title %>" required><br><br>
    <textarea name="description" required><%= image.description %></textarea><br><br>
    <button type="submit">Update</button>
</form>
<a href="/">Back to Gallery</a>
</body>
</html>